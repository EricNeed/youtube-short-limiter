EAS build precedure
    npx expo install --check
    npx expo-doctor@latest
    eas build --platform android --profile development
    

extra dependancies(that blank template not include):
    npx expo install  expo-android-usagestats @supersami/rn-foreground-service expo-notifications
    npx expo install expo-router react-native-safe-area-context react-native-screens expo-linking expo-constants expo-status-bar
    npx expo install react-native-gesture-handler
    npx expo install react-native-reanimated react-native-worklets
    npx expo install react-native-gifted-charts expo-linear-gradient react-native-svg
    npx expo install expo-symbols react-native-paper expo-haptics @react-native-async-storage/async-storage expo-font

web-version:
    npx expo install react-native-web
    press "w" after expo start

uninstall package:
    npm uninstall <\project-name>


check for unused dependancies:
    npx depcheck


download all dependancies in the package-lock.json:
    npm install


get the android folder:
    npx expo prebuild 
    


framework versions:
    npm install react@19.2.0 react-dom@19.2.0
    npm install expo@~55


add next:
    npx expo install @expo/ui
    